# Client-safe Supabase values. These can be exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-self-hosted-supabase.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Server-only Supabase values. Never expose these to client-side code.
SUPABASE_URL=https://your-self-hosted-supabase.example.com
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY

# Edge-function/server integration values.
EIA_API_KEY=YOUR_EIA_API_KEY

# Portfolio Manager / ENERGY STAR integration values.
PM_BASE_URL=https://portfoliomanager.energystar.gov/wstest
PM_USERNAME=YOUR_PM_USERNAME
PM_PASSWORD=YOUR_PM_PASSWORD
ENERGYSTAR_BASE_URL=https://portfoliomanager.energystar.gov/wstest
ENERGYSTAR_USERNAME=YOUR_ENERGYSTAR_USERNAME
ENERGYSTAR_PASSWORD=YOUR_ENERGYSTAR_PASSWORD
ENERGYSTAR_MAX_RETRIES=3
ENERGYSTAR_TIMEOUT_MS=20000
